{
  "name": "@multi-op/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsdown && electron .",
    "build": "tsdown",
    "clean": "rm -rf dist out",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@multi-op/core": "workspace:*",
    "@multi-op/database": "workspace:*",
    "@multi-op/shared": "workspace:*"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2"
  },
  "build": {
    "appId": "com.multi-op.app",
    "productName": "MultiOp",
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "mac": {
      "icon": "resources/icon.svg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "resources/icon.svg"
    },
    "linux": {
      "icon": "resources/icon.svg",
      "category": "Utility"
    }
  }
}
