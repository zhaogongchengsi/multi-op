{
  "name": "multi-op",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Multi-opener desktop app for TG, WA, TW platforms with hook & script system",
  "scripts": {
    "dev": "turbo dev",
    "dev:renderer": "cd packages/renderer && npx vite",
    "dev:desktop": "cd desktop && tsdown && electron .",
    "build": "pnpm build:libs && pnpm build:renderer && rm -rf desktop/dist/client && cp -r packages/renderer/dist desktop/dist/client",
    "build:libs": "tsdown -W -F @multi-op/shared -F @multi-op/core -F @multi-op/database -F @multi-op/desktop",
    "build:renderer": "cd packages/renderer && npx vite build",
    "package": "cd desktop && pnpm dist",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json}\""
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prettier": "^3.9.6",
    "tsdown": "^0.22.12",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  }
}
